programa
{
	
	funcao inicio()
	{
		real reais, dolar, euro

		escreva("Insira a quantidade em reais (R$): ")
		leia(reais)

		dolar = 5.50
		euro = 6.37

		escreva("Valor em dólares: US$", reais / dolar)
		escreva("\nValor em euros: €", reais / euro)
	}
}
