programa
{
	
	funcao inicio()
	{
		inteiro anos, meses, dias, idadedias

		escreva("Insira a sua idade dividida em anos, meses e dias: ")
		leia(anos, meses, dias)

		idadedias = (anos * 365) + (meses * 30) + dias

		escreva("Sua idade em dias é ", idadedias)
	}
}
