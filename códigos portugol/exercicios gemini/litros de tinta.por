programa
{
	
	funcao inicio()
	{
		real altura, largura, area, litros

		escreva("Insira a altura e largura da parede em metros: ")
		leia(altura, largura)

		area = altura * largura
		litros = area / 2

		escreva("Serão necessários ", litros ," litros de tinta para pintar a parede")
	}
}
