programa
{
	
	funcao inicio()
	{
		real consumo, distancia

		escreva("Insira a distância da viagem: ")
		leia(distancia)

		escreva("Insira o consumo médio de combustível do seu veículo: ")
		leia(consumo)

		escreva("Serão necessários ", distancia / consumo, " litros para realizar a viagem")
	}
}
